  "components": {
    "schemas": {
      "CreateBettingConfigRequest": {
        "type": "object",
        "properties": {
          "matchId": {
            "type": "string",
            "format": "uuid"
          },
          "groupId": {
            "type": "string",
            "format": "uuid"
          },
          "handicap": {
            "type": "number",
            "format": "double"
          },
          "favoredTeamId": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          },
          "odds": {
            "type": "number",
            "format": "double"
          },
          "minBetAmount": {
            "type": "number",
            "format": "double"
          },
          "maxBetAmount": {
            "type": "number",
            "format": "double"
          },
          "defaultBetAmount": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "isFixedBet": {
            "type": "boolean"
          },
          "bettingOpenTime": {
            "type": "string",
            "format": "date-time"
          },
          "bettingCloseTime": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "CreateGroupRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "maxMembers": {
            "type": "integer",
            "format": "int32"
          },
          "defaultBalance": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "CreateMatchRequest": {
        "type": "object",
        "properties": {
          "homeTeamId": {
            "type": "string",
            "format": "uuid"
          },
          "awayTeamId": {
            "type": "string",
            "format": "uuid"
          },
          "matchDay": {
            "type": "integer",
            "format": "int32"
          },
          "stage": {
            "type": "string",
            "nullable": true
          },
          "startTime": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "GoogleLoginRequest": {
        "type": "object",
        "properties": {
          "credential": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "GroupRole": {
        "enum": [
          "User",
          "Manager",
          "Admin"
        ],
        "type": "string"
      },
      "JoinGroupRequest": {
        "type": "object",
